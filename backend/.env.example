# ===== payclip 后端环境配置模板 =====
# 使用方法：复制本文件为 .env，填入真实值
#   cp .env.example .env
# 此文件会被提交到 git，不要在这里填真实密码

# 数据库连接串
# 注意：密码含特殊字符必须 URL 编码
#   @ → %40    ! → %21    # → %23    & → %26
# 示例：密码 payclip@2026! 编码后为 payclip%402026%21
# 注意：必须带 ?charset=utf8mb4 参数，否则中文会写入为 ?
DATABASE_URL=mysql+pymysql://用户名:密码URL编码@主机:端口/库名?charset=utf8mb4

# JWT 签名密钥（生产环境务必改成 32+ 字符的随机串）
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-secret-key-here

# 文件上传目录（收款截图等）
UPLOAD_DIR=./uploads
